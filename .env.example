# Kopie als .env speichern und mit echten Werten füllen.
# Die .env-Datei darf NIE committet werden (siehe .gitignore).

# --- Backend (FastAPI) ---

# Proxy zur FH-KI-API (vom /hint-Endpoint genutzt).
# FH_AI_API_URL=
# FH_AI_API_TOKEN=

# Kurs-Token, das Studierende bei der Anmeldung erhalten.
# Wird vom Backend bei jeder Anfrage geprüft (Auth, kein SSO/OAuth).
# COURSE_TOKEN=
